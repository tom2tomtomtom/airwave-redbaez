# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key
REACT_APP_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# LLM API Configuration
REACT_APP_LLM_API_KEY=your_openai_api_key
REACT_APP_LLM_API_URL=https://api.openai.com/v1/chat/completions
REACT_APP_LLM_MODEL=gpt-4

# Creatomate API Configuration (for video rendering)
REACT_APP_CREATOMATE_API_KEY=your_creatomate_api_key

# Optional SMTP Configuration (for email notifications)
REACT_APP_SMTP_HOST=your_smtp_host
REACT_APP_SMTP_PORT=your_smtp_port
REACT_APP_SMTP_USERNAME=your_smtp_username
REACT_APP_SMTP_PASSWORD=your_smtp_password
REACT_APP_SMTP_FROM_EMAIL=your_from_email

# Server Configuration
REACT_APP_SERVER_URL=http://localhost:3001
